{
  "name": "@wolffm/trader",
  "version": "1.5.1",
  "description": "Stock and crypto trading dashboard for hadoku",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WolffM/hadoku-trader.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "dependencies": {
    "@wolffm/prefs-client": "^1.0.2",
    "zod": "^4.1.12"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prepare": "husky || exit 0"
  },
  "peerDependencies": {
    "@wolffm/logger": ">=1.0.0",
    "@wolffm/task-ui-components": ">=1.0.0",
    "@wolffm/themes": ">=1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitejs/plugin-react": "^5.1.0",
    "@wolffm/logger": "^1.2.1",
    "@wolffm/task-ui-components": "^2.0.1",
    "@wolffm/themes": "^2.0.16",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.6.0",
    "stylelint": "^17.12.0",
    "stylelint-value-no-unknown-custom-properties": "^6.1.1",
    "typescript": "^5.6.3",
    "vite": "^7.1.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
