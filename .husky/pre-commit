#!/bin/sh
# Windows users: run via Git Bash or WSL
echo "🔍 Running pre-commit checks..."

# Capture originally staged files BEFORE any modifications
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Auto-fix linting and formatting issues
echo "📋 Running ESLint auto-fix..."
pnpm run lint:fix
if [ $? -ne 0 ]; then
  echo "❌ ESLint found errors that could not be auto-fixed."
  echo "💡 Please fix the errors manually before committing."
  exit 1
fi

echo "✨ Auto-formatting code..."
pnpm run format

echo "✅ Linting and formatting complete!"

# Bump version on every commit to ensure unique versions for publishing.
# Applies to all three packages in this repo:
#   @wolffm/trader         (package.json)
#   @wolffm/trader-worker  (worker/package.json)
#   hadoku-fidelity        (fidelity-api/pyproject.toml)
echo "📦 Bumping versions..."

# Bump a semver string — rolls patch over at .20 to keep numbers manageable
bump_version() {
  cur="$1"
  major=$(echo "$cur" | cut -d. -f1)
  minor=$(echo "$cur" | cut -d. -f2)
  patch=$(echo "$cur" | cut -d. -f3)
  if [ "$patch" -eq 20 ]; then
    echo "${major}.$((minor + 1)).0"
  else
    echo "${major}.${minor}.$((patch + 1))"
  fi
}

# 1. @wolffm/trader (root package.json)
trader_cur=$(node -p "require('./package.json').version")
trader_new=$(bump_version "$trader_cur")
node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
pkg.version = '${trader_new}';
fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
"
echo "  @wolffm/trader: ${trader_cur} → ${trader_new}"

# 2. @wolffm/trader-worker (worker/package.json)
worker_cur=$(node -p "require('./worker/package.json').version")
worker_new=$(bump_version "$worker_cur")
node -e "
const fs = require('fs');
const pkg = JSON.parse(fs.readFileSync('worker/package.json', 'utf8'));
pkg.version = '${worker_new}';
fs.writeFileSync('worker/package.json', JSON.stringify(pkg, null, 2) + '\n');
"
echo "  @wolffm/trader-worker: ${worker_cur} → ${worker_new}"

# 3. hadoku-fidelity (fidelity-api/pyproject.toml)
fidelity_cur=$(python3 -c "
import re
m = re.search(r'^version = \"(.+?)\"', open('fidelity-api/pyproject.toml').read(), re.M)
print(m.group(1))
")
fidelity_new=$(bump_version "$fidelity_cur")
FIDELITY_NEW="$fidelity_new" python3 -c "
import re, os
path = 'fidelity-api/pyproject.toml'
content = open(path).read()
updated = re.sub(r'^version = \".+?\"', 'version = \"' + os.environ['FIDELITY_NEW'] + '\"', content, flags=re.M)
open(path, 'w').write(updated)
"
echo "  hadoku-fidelity: ${fidelity_cur} → ${fidelity_new}"

# Update root lockfile
pnpm install --lockfile-only

# Stage all version file changes
git add package.json worker/package.json fidelity-api/pyproject.toml pnpm-lock.yaml

# Re-stage only the files that were originally staged (after lint/format may have modified them)
if [ -n "${STAGED_FILES}" ]; then
  echo "${STAGED_FILES}" | xargs -r git add
fi

echo "✅ All pre-commit checks passed!"
